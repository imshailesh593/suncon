# ──────────────────────────────────────────────
# Copy this to .env.local and fill in your values
# ──────────────────────────────────────────────

# Public canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://suncon.com.au

# Laravel CMS REST API base URL — leave blank to use mock data
# NEXT_PUBLIC_API_URL=https://api.suncon.com.au/api

# Secret shared with Laravel for ISR cache revalidation
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=change-me-to-a-long-random-string
